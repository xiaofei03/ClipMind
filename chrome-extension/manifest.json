{
  "manifest_version": 3,
  "name": "影记 YouTube 助手",
  "version": "0.1.0",
  "description": "从当前 YouTube 页面抓取标题、字幕和元信息，并发送到影记本地服务。",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://127.0.0.1:8765/*",
    "http://127.0.0.1:4173/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "发送到影记",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/watch*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
