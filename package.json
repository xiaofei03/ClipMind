{
  "name": "clipmind",
  "version": "0.1.0",
  "description": "Local-first web app that turns video links into illustrated notes, Word documents, mind maps, and subtitle summaries.",
  "type": "module",
  "bin": {
    "clipmind-core": "src/server.js"
  },
  "scripts": {
    "start": "node ./scripts/web_server.cjs",
    "web": "node ./scripts/web_server.cjs",
    "frontend:dev": "vite",
    "frontend:build": "vite build",
    "frontend:preview": "vite preview --host 127.0.0.1",
    "check": "node ./src/server.js --check",
    "web:check": "node ./scripts/verify_web_ui.cjs",
    "article:check": "node ./scripts/verify_article_output.cjs",
    "media:probe": "node ./scripts/probe_media_url.cjs",
    "frames:plan-refine": "node ./scripts/plan_refinement_frames.cjs",
    "frames:execute-refine": "node ./scripts/execute_refinement_frames.cjs"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "main": "index.js",
  "keywords": [
    "video",
    "notes",
    "summarization",
    "multimodal",
    "react",
    "qwen"
  ],
  "author": "",
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^1.17.0",
    "ogl": "^1.0.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
